@{
    ViewData["Title"] = "Página inicial";
}

<!-- comentário em HTML  -->
@*   comentário em RAZOR  *@

@*
<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
*@

<div class="text-center">
    <h1 class="display-4">Cálculo das Raízes de uma Equação de 2º Grau</h1>
    <img src="https://images.educamaisbrasil.com.br/content/banco_de_imagens/mb/D/formula-de-bhaskara-equacao.jpg"
     alt="Imagem com a fórmula resolvente de 2º grau a ser aplicada."
     width="200px"
     style="filter: invert(1);" />
</div>


<form method="post">
    <div>
        indique o valor parâmetro <b>a</b>: <input type="text" name="A" /> <br />
        indique o valor parâmetro <b>b</b>: <input type="text" name="B" /> <br />
        indique o valor parâmetro <b>c</b>: <input type="text" name="C" /> <br />
        <input type="submit" value="Calcular" />
    </div>
    @*
    <input type="text" id="A" />
    <input type="text" name="A" />
    O 'id' é para referenciar a textbox no javascript no browser.
    No servidor usa-se o 'name'.
    *@
</form>

@*
<div>
    <br/> <p>Raízes da equação:</p>
    <p>x1=@ViewBag.X1</p>
    <p>x2=@ViewBag.X2</p>

</div>
*@

<br />

@* Se houver errom escrever a mensagem de erro *@
@if (ViewBag.Erro != null)
        @ViewBag.Erro

@* apresentar o resultado caso exista *@
@if (ViewBag.X1 != null && ViewBag.X2 != null)
{
    <p><strong>X1 =</strong> @ViewBag.X1</p>
    <p><strong>X2 =</strong> @ViewBag.X2</p>
}
